{
  "description": "Account guard: checks logged-in Claude account against per-folder policy before each prompt",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/account_guard_hook.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
